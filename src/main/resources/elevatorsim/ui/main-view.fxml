<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1180.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1" fx:controller="elevatorsim.ui.SimulationController">
    <top>
        <VBox spacing="10.0" styleClass="top-bar">
            <padding>
                <Insets bottom="12.0" left="16.0" right="16.0" top="14.0" />
            </padding>
            <Label styleClass="app-title" text="Elevator Simulation" />
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Button fx:id="startPauseButton" onAction="#handleStartPause" text="Start" />
                <Button onAction="#handleStep" text="Step" />
                <Button onAction="#handleReset" text="Reset" />
                <Separator orientation="VERTICAL" />
                <Button onAction="#handleSameDirectionScenario" text="Same Direction" />
                <Button onAction="#handleOppositeDirectionScenario" text="Opposite Direction" />
                <Label fx:id="simulationStateLabel" styleClass="state-label" text="Tick 0" />
            </HBox>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="building-scroll">
            <content>
                <GridPane fx:id="buildingGrid" hgap="6.0" vgap="6.0">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                </GridPane>
            </content>
        </ScrollPane>
    </center>
    <right>
        <VBox prefWidth="340.0" spacing="10.0" styleClass="side-panel">
            <padding>
                <Insets bottom="16.0" left="14.0" right="14.0" top="16.0" />
            </padding>
            <Label styleClass="section-title" text="Passenger Request" />
            <ComboBox fx:id="passengerTypeComboBox" maxWidth="Infinity" />
            <HBox spacing="8.0">
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="field-label" text="Start" />
                    <Spinner fx:id="startFloorSpinner" editable="true" maxWidth="Infinity" />
                </VBox>
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="field-label" text="Destination" />
                    <Spinner fx:id="endFloorSpinner" editable="true" maxWidth="Infinity" />
                </VBox>
            </HBox>
            <Button maxWidth="Infinity" onAction="#handleRequestPassenger" text="Request Elevator" />
            <Button maxWidth="Infinity" onAction="#handleGeneratePassengers" text="Generate Random Passengers" />
            <Separator />
            <Label styleClass="section-title" text="Elevators" />
            <ScrollPane fitToWidth="true" prefHeight="210.0" styleClass="status-scroll">
                <content>
                    <VBox fx:id="elevatorStatusBox" spacing="8.0" />
                </content>
            </ScrollPane>
            <Label styleClass="section-title" text="Event Log" />
            <TextArea fx:id="eventLogTextArea" editable="false" prefRowCount="14" wrapText="true" VBox.vgrow="ALWAYS" />
        </VBox>
    </right>
</BorderPane>
